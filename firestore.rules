rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — profile data + saved team
    match /users/{userId} {
      // Public read needed: login looks up email by username before the user is authenticated
      allow read: if true;
      // Only the authenticated owner can create or update their own document
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      // Nobody can delete user documents from the client
      allow delete: if false;
    }

    // Teams collection — public leaderboard
    match /teams/{teamId} {
      // Anyone can read (public leaderboard)
      allow read: if true;
      // Only the authenticated owner can write their own team document
      allow write: if request.auth != null && request.auth.uid == teamId;
    }
  }
}
